generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  age Int
  role Role
}